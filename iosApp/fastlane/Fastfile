default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # Set up App Store Connect API key
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true,
      duration: 1200,
    )

    # Create a temporary keychain for CI so codesign doesn't hang
    if is_ci
      create_keychain(
        name: "ci_keychain",
        password: "ci_password",
        default_keychain: true,
        unlock: true,
        timeout: 3600,
        lock_when_sleeps: false,
      )
    end

    # Fetch signing certificates and profiles
    keychain_name = is_ci ? "ci_keychain" : nil
    keychain_password = is_ci ? "ci_password" : nil

    match(
      type: "appstore",
      readonly: is_ci,
      api_key: api_key,
      keychain_name: keychain_name,
      keychain_password: keychain_password,
    )

    # Disable automatic signing for CI
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "iosApp.xcodeproj",
      team_id: "2GGQ4M8T47",
      bundle_identifier: "com.andriybobchuk.mooney",
      profile_name: "match AppStore com.andriybobchuk.mooney",
      code_sign_identity: "Apple Distribution",
    )

    # Read version from gradle.properties (single source of truth)
    gradle_props = File.read("../gradle.properties")
    app_version = gradle_props.match(/app\.version=(.+)/)[1].strip

    # Set marketing version from gradle.properties
    increment_version_number(
      version_number: app_version,
      xcodeproj: "iosApp.xcodeproj",
    )

    # Increment build number to current timestamp (always unique)
    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj: "iosApp.xcodeproj",
    )

    # Build the app
    build_app(
      project: "iosApp.xcodeproj",
      scheme: "iosApp",
      destination: "generic/platform=iOS",
      clean: false,
      export_method: "app-store",
      xcargs: "OTHER_CODE_SIGN_FLAGS='--keychain ci_keychain'",
      export_options: {
        provisioningProfiles: {
          "com.andriybobchuk.mooney" => "match AppStore com.andriybobchuk.mooney",
        },
      },
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )

    # Clean up keychain
    if is_ci
      delete_keychain(name: "ci_keychain")
    end
  end
end
