default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # Set up App Store Connect API key
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true,
      duration: 1200,
    )

    # Fetch signing certificates and profiles
    match(
      type: "appstore",
      readonly: is_ci,
      api_key: api_key,
    )

    # Increment build number to current timestamp (always unique)
    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj: "iosApp.xcodeproj",
    )

    # Build the app
    build_app(
      project: "iosApp.xcodeproj",
      scheme: "iosApp",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.andriybobchuk.mooney" => "match AppStore com.andriybobchuk.mooney",
        },
      },
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end
end
