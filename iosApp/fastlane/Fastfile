default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # Set up App Store Connect API key
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true,
      duration: 1200,
    )

    # Create a temporary keychain for CI so codesign doesn't hang
    if is_ci
      create_keychain(
        name: "ci_keychain",
        password: "ci_password",
        default_keychain: true,
        unlock: true,
        timeout: 3600,
        lock_when_sleeps: false,
      )
    end

    # Fetch signing certificates and profiles
    keychain_name = is_ci ? "ci_keychain" : nil
    keychain_password = is_ci ? "ci_password" : nil

    match(
      type: "appstore",
      readonly: is_ci,
      api_key: api_key,
      keychain_name: keychain_name,
      keychain_password: keychain_password,
    )

    # Disable automatic signing for CI
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "iosApp.xcodeproj",
      team_id: "2GGQ4M8T47",
      bundle_identifier: "com.andriybobchuk.mooney",
      profile_name: "match AppStore com.andriybobchuk.mooney",
      code_sign_identity: "Apple Distribution",
    )

    # Read version from gradle.properties (single source of truth)
    gradle_props = File.read("../../gradle.properties")
    app_version = gradle_props.match(/app\.version=(.+)/)[1].strip

    # Set marketing version from gradle.properties
    increment_version_number(
      version_number: app_version,
      xcodeproj: "iosApp.xcodeproj",
    )

    # Increment build number to current timestamp (always unique)
    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj: "iosApp.xcodeproj",
    )

    # Build the app
    build_app(
      project: "iosApp.xcodeproj",
      scheme: "iosApp",
      destination: "generic/platform=iOS",
      clean: false,
      export_method: "app-store",
      xcargs: "OTHER_CODE_SIGN_FLAGS='--keychain ci_keychain'",
      export_options: {
        provisioningProfiles: {
          "com.andriybobchuk.mooney" => "match AppStore com.andriybobchuk.mooney",
        },
      },
    )

    # "What to Test" notes for TestFlight. The issue agent writes a one-line
    # changelog to fastlane/changelog.txt describing the fix it shipped; fall
    # back to a generic line for manual releases that don't set it.
    changelog_path = "fastlane/changelog.txt"
    test_notes = if File.exist?(changelog_path) && !File.read(changelog_path).strip.empty?
      File.read(changelog_path).strip
    else
      "Bug fixes and improvements."
    end

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: test_notes,
    )

    # NOTE: dSYM upload to Crashlytics is intentionally NOT done here.
    # `upload_symbols_to_crashlytics` can't locate Firebase's upload-symbols
    # binary when the SDK is installed via SwiftPM (it expects CocoaPods).
    # Instead, dSYMs reach Firebase via Apple's auto-export: turn on
    # "Include Bitcode" -> No (it's already off) and let App Store Connect
    # process the dSYMs; Firebase pulls them via the Apple ID connection in
    # the Firebase console. If symbols don't appear within a few hours after
    # a TestFlight build, the manual fallback is:
    #   bundle exec fastlane run download_dsyms version:LATEST
    #   bundle exec fastlane run upload_symbols_to_crashlytics gsp_path:iosApp/GoogleService-Info.plist
    # run locally (where the Firebase SPM checkout is on disk).

    # Clean up keychain
    if is_ci
      delete_keychain(name: "ci_keychain")
    end
  end
end
